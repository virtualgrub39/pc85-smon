PRINT: PROCEDURE(PTR) EXTERNAL;
    DECLARE PTR ADDRESS;
END PRINT;

PRINT_CRLF: PROCEDURE EXTERNAL;
END PRINT_CRLF;

PRINTLN: PROCEDURE(PTR) EXTERNAL;
    DECLARE PTR ADDRESS;
END PRINTLN;

PRINT_DEC: PROCEDURE(NUM) EXTERNAL;
    DECLARE NUM WORD;
END PRINT_DEC;

PRINT_NIBBLE: PROCEDURE(N) EXTERNAL;
    DECLARE N BYTE;
END PRINT_NIBBLE;

PRINT_HEX8: PROCEDURE(NUM) EXTERNAL;
    DECLARE NUM BYTE;
END PRINT_HEX8;

PRINT_HEX16: PROCEDURE(NUM) EXTERNAL;
    DECLARE NUM WORD;
END PRINT_HEX16;

PRINTF: PROCEDURE(FMT, ARGS) EXTERNAL;
    DECLARE (FMT, ARGS) ADDRESS;
END PRINTF;

READLINE: PROCEDURE(BUFFER, MAXLEN, ECHO) BYTE EXTERNAL;
    DECLARE BUFFER ADDRESS;
    DECLARE MAXLEN BYTE;
    DECLARE ECHO BOOL;
END READLINE;
