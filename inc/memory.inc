MEMCMP: PROCEDURE(A, B, LEN) BOOL EXTERNAL;
        DECLARE (A, B) ADDRESS;
        DECLARE LEN BYTE;
END MEMCMP;

STRLEN: PROCEDURE(STR) BYTE EXTERNAL;
        DECLARE STR ADDRESS;
END STRLEN;

STRCMP: PROCEDURE(A, B) BOOL EXTERNAL;
        DECLARE (A, B) ADDRESS;
END STRCMP;

MEMCPY: PROCEDURE(DST, SRC, N) EXTERNAL;
        DECLARE (DST, SRC) ADDRESS;
        DECLARE N BYTE;
END MEMCPY;

ATOI: PROCEDURE (STR) WORD EXTERNAL;
    DECLARE STR ADDRESS;
END ATOI;

STRTOK: PROCEDURE (STR, DELIM) ADDRESS EXTERNAL;
    DECLARE STR ADDRESS;
    DECLARE DELIM BYTE; 
END STRTOK;
