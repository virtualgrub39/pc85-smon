MAIN: DO;

$INCLUDE(inc/const.inc)
$INCLUDE(inc/misc.inc)
$INCLUDE(inc/conio.inc)
$INCLUDE(inc/syscon.inc)

    ASCII_TO_HEX: PROCEDURE (CH) BYTE;
        DECLARE CH BYTE;
        IF CH >= 'A' THEN RETURN (CH - 'A') + 10;
        RETURN CH - '0';
    END ASCII_TO_HEX;

    MAKE_HEX8: PROCEDURE (HNIBBLE, LNIBBLE) BYTE;
        DECLARE (HNIBBLE, LNIBBLE) BYTE;
        RETURN SHL(ASCII_TO_HEX(HNIBBLE), 4) OR ASCII_TO_HEX(LNIBBLE);
    END MAKE_HEX8;

    READ_HEX8: PROCEDURE (LINE) BYTE;
        DECLARE LINE ADDRESS;
        DECLARE CH BASED LINE BYTE;
        DECLARE NIBBLE BYTE;

        NIBBLE = CH;
        LINE = LINE + 1;
        RETURN MAKE_HEX8(NIBBLE, CH);
    END READ_HEX8;

    READ_HEX16: PROCEDURE (LINE) ADDRESS;
        DECLARE LINE ADDRESS;
        DECLARE (HB, LB) BYTE;
        DECLARE H_WORD ADDRESS;

        HB = READ_HEX8(LINE);
        LINE = LINE + 2;
        LB = READ_HEX8(LINE);
        
        H_WORD = HB;
        RETURN (H_WORD * 256) + LB;
    END READ_HEX16;

    DECLARE RECORD_DATA LITERALLY '00H';
    DECLARE RECORD_END LITERALLY '01H';

    MONITOR_LOAD: PROCEDURE (LINE, LEN) BYTE; 
        DECLARE LINE ADDRESS; 
        DECLARE LEN BYTE; 

        DECLARE (COUNT, TYPE, I) BYTE;
        DECLARE ADDR ADDRESS;
        DECLARE TARGET BASED ADDR BYTE;
        DECLARE (CHECKSUM, LOCAL_CHECKSUM, DATA_BYTE) BYTE;

        IF LEN < 8 THEN DO;
            CALL CONOUT(BEL);
            CALL PRINTLN(.('ERR. RECORD TOO SHORT', 0));
            RETURN FALSE;
        END;

        LOCAL_CHECKSUM = 0;

        COUNT = READ_HEX8(LINE);
        LINE = LINE + 2;
        LOCAL_CHECKSUM = LOCAL_CHECKSUM + COUNT;

        ADDR = READ_HEX16(LINE);
        LINE = LINE + 4;
        LOCAL_CHECKSUM = LOCAL_CHECKSUM + HIGH(ADDR) + LOW(ADDR);

        TYPE = READ_HEX8(LINE);
        LINE = LINE + 2;
        LOCAL_CHECKSUM = LOCAL_CHECKSUM + TYPE;

        IF (ADDR < 2000H) AND (TYPE = RECORD_DATA) THEN DO;
            CALL CONOUT(BEL);
            CALL PRINTLN(.('ERR. PROTECTED MEM', 0));
            RETURN FALSE;
        END;

        I = 0;
        DO WHILE I < COUNT;
            DATA_BYTE = READ_HEX8(LINE);
            LOCAL_CHECKSUM = LOCAL_CHECKSUM + DATA_BYTE;
            
            IF TYPE = RECORD_DATA THEN DO;
                TARGET = DATA_BYTE;
                ADDR = ADDR + 1;
            END;
            
            LINE = LINE + 2;
            I = I + 1;
        END;

        CHECKSUM = READ_HEX8(LINE);
        LOCAL_CHECKSUM = LOCAL_CHECKSUM + CHECKSUM;

        IF (LOCAL_CHECKSUM AND 0FFH) <> 0 THEN DO;
            CALL CONOUT(BEL);
            CALL PRINTLN(.('ERR. CHECKSUM', 0));
            RETURN FALSE;
        END;

        IF TYPE = RECORD_DATA THEN RETURN FALSE;
        ELSE RETURN TRUE; 
    END MONITOR_LOAD;

    MONITOR_EXEC: PROCEDURE (LINE, LEN);
        DECLARE LINE ADDRESS;
        DECLARE LEN BYTE; 

        DECLARE ADDR ADDRESS;

        IF LEN <> 4 THEN DO;
            CALL CONOUT(BEL);
            CALL PRINTLN(.('ERR. NOT AN ADDRESS', 0));
            RETURN;
        END;

        ADDR = READ_HEX16(LINE);

        CALL EXEC(ADDR);
    END;

    MONITOR_MAIN: PROCEDURE PUBLIC;
        DECLARE LINE_MAX_LEN LITERALLY '64';
        DECLARE LINE (LINE_MAX_LEN) BYTE;
        DECLARE LINE_LEN BYTE;
        DECLARE CMD BYTE;
        
        CALL CONINIT;
        CALL PRINTLN(.('PC85/MONITOR', 0));
        
        DO WHILE TRUE;
        MAIN_SKIP:
            LINE_LEN = READLINE(.LINE, LINE_MAX_LEN, TRUE);
            IF LINE_LEN = 0 THEN GOTO MAIN_SKIP;
            CMD = LINE(0);
        
            IF CMD = ':' THEN DO;
                DECLARE IS_EOF BYTE;
                
                IS_EOF = MONITOR_LOAD((.LINE)+1, LINE_LEN-1);
                
                DO WHILE IS_EOF = FALSE;
                NEXT_RECORD_LINE:
                    LINE_LEN = READLINE(.LINE, LINE_MAX_LEN, FALSE);
                    
                    IF LINE_LEN = 0 THEN GOTO NEXT_RECORD_LINE;
                    IF LINE(0) = ':' THEN DO;
                        IS_EOF = MONITOR_LOAD((.LINE)+1, LINE_LEN-1);
                    END;
                    ELSE DO;
                        CALL PRINTLN(.('ERR. BAD HEX STREAM', 0));
                        IS_EOF = TRUE; 
                    END;
                END;
                
                CALL PRINTLN(.('LOAD OK', 0));
            END;
            ELSE IF CMD = '$' THEN CALL MONITOR_EXEC((.LINE)+1, LINE_LEN-1);
            ELSE DO;
                CALL CONOUT(BEL);
                CALL CONOUT(CMD);
                CALL PRINTLN(.('?', 0));
            END;
        END;
    END;
END MAIN;
